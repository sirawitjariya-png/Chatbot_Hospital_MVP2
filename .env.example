# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Optional: override default models ─────────────────────────────────────────
# ROUTER_MODEL=gpt-4o-mini   # classifier (cheap)
# ANSWER_MODEL=gpt-4.1       # user-facing reply (quality)
# OPENAI_TIMEOUT_S=60

# ── Optional: protect the /chat endpoint ──────────────────────────────────────
# CHAT_API_KEY=your-secret-key-here

# ── LINE Messaging API ─────────────────────────────────────────────────────────
# LINE_CHANNEL_SECRET=...
# LINE_CHANNEL_ACCESS_TOKEN=...

# ── Facebook Messenger ─────────────────────────────────────────────────────────
# FB_PAGE_ACCESS_TOKEN=...
# FB_VERIFY_TOKEN=change-me
